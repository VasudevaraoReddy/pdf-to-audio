# Port the API server listens on
PORT=4000

# Absolute path to your Google Cloud service-account JSON key.
# 1. Create a GCP project and enable the "Cloud Text-to-Speech API".
# 2. Enable billing (free tier ~1M characters/month).
# 3. Create a service account, download its JSON key, and point to it here.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-key.json

# Max upload size in megabytes.
MAX_UPLOAD_MB=20

# Hard cap on characters sent to TTS per job (cost guard). 0 = no limit.
MAX_CHARS=200000

# Secret used to sign login (JWT) tokens. Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string

# ---- Gemini-TTS voice settings ----
# Gemini-TTS model. Options: gemini-3.1-flash-tts-preview, gemini-2.5-flash-tts,
# gemini-2.5-flash-lite-preview-tts, gemini-2.5-pro-tts
TTS_MODEL=gemini-3.1-flash-tts-preview
# A multilingual Gemini voice (e.g. Vindemiatrix, Kore, Achernar, Puck, Zephyr).
TTS_VOICE=Vindemiatrix
# Default narration style prompt (users can override per upload in the UI).
TTS_PROMPT=Read this aloud clearly at a natural, calm pace, like narrating a book to a listener.
# Optional delivery tuning.
TTS_SPEAKING_RATE=1
TTS_PITCH=0
# How many TTS requests to run in parallel (higher = faster, more rate-limit risk).
TTS_CONCURRENCY=5
# Set to 1 to skip Google entirely and emit short silent clips — handy for
# testing the UI/streaming without billing or the Vertex AI API enabled.
TTS_FAKE=0
